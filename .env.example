# Slacker configuration
# Copy to .env and fill in values before deploying with real Slack data

# Port the Node.js server listens on (default: 8391)
PORT=8391

# Set to 'false' once real Slack events are flowing in
MOCK_EVENTS=true

# Slack app credentials — obtain from https://api.slack.com/apps
# Required for signature verification on /webhook/slack
SLACK_SIGNING_SECRET=

# Optional: Slack Bot token (for future outbound API calls, e.g. fetching channel names)
SLACK_BOT_TOKEN=
