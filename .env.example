# Slacker configuration
# Set these as Environment= lines in the systemd unit (or export before running locally)

# Port the server listens on (default: 8391, auto-assigned by r3x-deploy-go-repo)
PORT=8391

# Set to 'false' once real Slack events are flowing in
MOCK_EVENTS=true

# Slack app credentials — obtain from https://api.slack.com/apps
# Required for webhook signature verification
SLACK_SIGNING_SECRET=

# Optional: Slack Bot token (reserved for future outbound API calls)
SLACK_BOT_TOKEN=
